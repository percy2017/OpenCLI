# CloudCLI UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'cloudcli status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   claude-code-ui    - Start the server (default)
#   cloudcli start    - Start the server
#   cloudcli status   - Show configuration and data locations
#   cloudcli help     - Show help information
#   cloudcli version  - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
SERVER_PORT=3001
#Frontend port
VITE_PORT=5173

# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# Public address browsers use to reach the server. Must match what the user
# types in the URL bar (e.g. `http://192.168.0.10:3001`). When set, Vite's dev
# proxy routes /api, /ws, /shell, and /plugin-ws to the backend via this
# address so WebSocket upgrades don't get lost between hosts.
# PROXY_HOST=http://192.168.0.10:3001

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
DATABASE_PATH=./database/auth.db
#
# Claude Code context window size (maximum tokens per session)
VITE_CONTEXT_WINDOW=1000000
CONTEXT_WINDOW=1000000

# =============================================================================
# WORKSPACE ROOT
# =============================================================================
# Directory the project-creation wizard and /api/browse-filesystem treat as the
# safe browsing root. Defaults to os.homedir() (i.e. /root when running as
# root), which then collides with the FORBIDDEN_WORKSPACE_PATHS list and the
# folder picker returns 403. Pin it to a non-system path here.
WORKSPACES_ROOT=/

# =============================================================================
# RAG — EMBEDDING PROVIDER
# =============================================================================
# Which provider to use for vectorizing documents and queries.
# Supported: ollama (local, default) | minimax | openai
RAG_EMBEDDING_PROVIDER=ollama

# Ollama (default). Runs on localhost:11434 by default; install with
# `curl -fsSL https://ollama.com/install.sh | sh` then `ollama pull mxbai-embed-large`.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
# How long Ollama keeps the model loaded after a request. 5m avoids re-loading
# the model on every chat ping.
OLLAMA_KEEP_ALIVE=5m
# Ollama batch size per request (sent as a single `input` array).
OLLAMA_EMBEDDING_BATCH_SIZE=32
# Retry on transient errors before failing the index job.
OLLAMA_EMBEDDING_RETRIES=2

# Generic chunking params (apply to any provider).
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# =============================================================================
# VOICE (read-aloud via the mmx MiniMax CLI)
# =============================================================================
# Path to the mmx binary. Defaults to "mmx" (on PATH).
MMX_BIN=mmx

# Default TTS model passed to `mmx speech synthesize --model`.
VOICE_DEFAULT_MODEL=speech-2.8-hd

# Default voice id passed to `mmx speech synthesize --voice`.
VOICE_DEFAULT_VOICE=English_expressive_narrator

# Per-request TTS timeout in milliseconds (default: 300000 = 5 min).
VOICE_TIMEOUT_MS=300000

# Timeout for `mmx quota show` calls in the MiniMax settings tab (default: 30000).
MMX_TIMEOUT_MS=30000

# =============================================================================
# UI TABS
# =============================================================================
# Show the "Terminal" (agent shell, xterm.js) tab in the main content header.
# Set to "false" to hide it. The other "Terminal" (the Terminal module) is
# controlled independently from Settings → Terminal.
# Default: true
VITE_SHOW_SHELL_TAB=false
